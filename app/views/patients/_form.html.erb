<%= form_with(model: patient) do |form| %>
  <% if patient.errors.any? %>
    <div role="alert" class="alert alert-error mb-6">
      <ul class="list-disc ml-4">
        <% patient.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <fieldset class="fieldset md:col-span-2">
      <%= form.label :name, "Nome completo", class: "fieldset-label" %>
      <%= form.text_field :name, class: "input input-bordered w-full #{patient.errors[:name].any? ? 'input-error' : ''}", placeholder: "Nome do paciente" %>
      <% if patient.errors[:name].any? %>
        <p class="fieldset-label text-error"><%= patient.errors[:name].first %></p>
      <% end %>
    </fieldset>

    <fieldset class="fieldset">
      <%= form.label :birth_date, "Data de nascimento", class: "fieldset-label" %>
      <%= form.date_field :birth_date, class: "input input-bordered w-full #{patient.errors[:birth_date].any? ? 'input-error' : ''}" %>
      <% if patient.errors[:birth_date].any? %>
        <p class="fieldset-label text-error"><%= patient.errors[:birth_date].first %></p>
      <% end %>
    </fieldset>

    <fieldset class="fieldset">
      <%= form.label :phone, "Telefone", class: "fieldset-label" %>
      <%= form.text_field :phone, class: "input input-bordered w-full #{patient.errors[:phone].any? ? 'input-error' : ''}", placeholder: "(11) 99999-9999" %>
      <% if patient.errors[:phone].any? %>
        <p class="fieldset-label text-error"><%= patient.errors[:phone].first %></p>
      <% end %>
    </fieldset>

    <fieldset class="fieldset md:col-span-2">
      <%= form.label :email, "Email", class: "fieldset-label" %>
      <%= form.email_field :email, class: "input input-bordered w-full #{patient.errors[:email].any? ? 'input-error' : ''}", placeholder: "paciente@email.com" %>
      <% if patient.errors[:email].any? %>
        <p class="fieldset-label text-error"><%= patient.errors[:email].first %></p>
      <% end %>
    </fieldset>

    <fieldset class="fieldset md:col-span-2">
      <%= form.label :description, "Observações", class: "fieldset-label" %>
      <%= form.textarea :description, rows: 3, class: "textarea textarea-bordered w-full", placeholder: "Informações adicionais sobre o paciente" %>
    </fieldset>
  </div>

  <div class="mt-6 flex gap-3">
    <%= form.submit class: "btn btn-primary", value: "Cadastrar Paciente"%>
    <%= link_to "Cancelar", patients_path, class: "btn btn-ghost" %>
  </div>
<% end %>
