<% content_for :title, "Pacientes" %>

<div class="max-w-4xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Pacientes</h1>
    <%= link_to "Novo paciente", new_patient_path, class: "btn btn-primary btn-sm" %>
  </div>

  <% if @patients.any? %>
    <div class="overflow-x-auto">
      <table class="table table-zebra">
        <thead>
          <tr>
            <th>Nome</th>
            <th>Telefone</th>
            <th>Email</th>
            <th>Nascimento</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @patients.each do |patient| %>
            <tr>
              <td class="font-medium"><%= patient.name %></td>
              <td><%= patient.phone %></td>
              <td><%= patient.email.presence || "—" %></td>
              <td><%= patient.birth_date.strftime("%d/%m/%Y") %></td>
              <td class="text-right">
                <div class="flex gap-2 justify-end">
                  <%= link_to "Ver", patient, class: "btn btn-ghost btn-xs" %>
                  <%= link_to "Editar", edit_patient_path(patient), class: "btn btn-ghost btn-xs" %>
                  <%= button_to "Remover", patient, method: :delete, class: "btn btn-ghost btn-xs text-error", data: { turbo_confirm: "Remover paciente?" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="hero min-h-48">
      <div class="hero-content text-center">
        <div>
          <p class="text-base-content/60 mb-4">Nenhum paciente cadastrado ainda.</p>
          <%= link_to "Cadastrar primeiro paciente", new_patient_path, class: "btn btn-primary" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
