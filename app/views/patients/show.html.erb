<% content_for :title, @patient.name %>

<div class="max-w-2xl mx-auto">
  <div class="flex justify-between items-start mb-6">
    <div>
      <h1 class="text-2xl font-bold"><%= @patient.name %></h1>
      <p class="text-base-content/60 text-sm mt-1">Cadastrado em <%= @patient.created_at.strftime("%d/%m/%Y") %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Editar", edit_patient_path(@patient), class: "btn btn-sm" %>
      <%= button_to "Remover", @patient, method: :delete, class: "btn btn-sm btn-error", data: { turbo_confirm: "Remover paciente?" } %>
    </div>
  </div>

  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <dl class="grid grid-cols-2 gap-4">
        <div>
          <dt class="text-sm text-base-content/60">Nascimento</dt>
          <dd class="font-medium"><%= @patient.birth_date.strftime("%d/%m/%Y") %></dd>
        </div>
        <div>
          <dt class="text-sm text-base-content/60">Telefone</dt>
          <dd class="font-medium"><%= @patient.phone %></dd>
        </div>
        <% if @patient.email.present? %>
          <div class="col-span-2">
            <dt class="text-sm text-base-content/60">Email</dt>
            <dd class="font-medium"><%= @patient.email %></dd>
          </div>
        <% end %>
        <% if @patient.description.present? %>
          <div class="col-span-2">
            <dt class="text-sm text-base-content/60">Observações</dt>
            <dd class="mt-1"><%= @patient.description %></dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>

  <div class="mt-4">
    <%= link_to "← Voltar para pacientes", patients_path, class: "link link-hover text-sm" %>
  </div>
</div>
