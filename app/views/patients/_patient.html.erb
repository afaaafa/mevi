<div id="<%= dom_id patient %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">User:</strong>
    <%= patient.user_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= patient.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Birth date:</strong>
    <%= patient.birth_date %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Email:</strong>
    <%= patient.email %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Phone:</strong>
    <%= patient.phone %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= patient.description %>
  </div>
</div>
